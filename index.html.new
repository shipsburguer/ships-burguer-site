  <script>
    const N8N_WEBHOOK_URL = "https://ships.app.n8n.cloud/webhook/clube-ships";
    const RAW_VITE_GA_ID = "%VITE_GA_ID%";
    const RAW_VITE_CLARITY_ID = "%VITE_CLARITY_ID%";
    const GA_ID = window.SHIP_ANALYTICS_CONFIG?.GA_ID || window.NEXT_PUBLIC_GA_ID || (RAW_VITE_GA_ID.startsWith("%") ? "" : RAW_VITE_GA_ID);
    const CLARITY_ID = window.SHIP_ANALYTICS_CONFIG?.CLARITY_ID || window.NEXT_PUBLIC_CLARITY_ID || (RAW_VITE_CLARITY_ID.startsWith("%") ? "" : RAW_VITE_CLARITY_ID);

    function loadGoogleAnalytics(measurementId) {
      if (!measurementId) return;

      const gaScript = document.createElement("script");
      gaScript.async = true;
      gaScript.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(measurementId)}`;
      document.head.appendChild(gaScript);

      window.dataLayer = window.dataLayer || [];
      window.gtag = function gtag(){ window.dataLayer.push(arguments); };
      window.gtag("js", new Date());
      window.gtag("config", measurementId);
    }

    function loadMicrosoftClarity(projectId) {
      if (!projectId) return;

      window.clarity = window.clarity || function clarity(){ (window.clarity.q = window.clarity.q || []).push(arguments); };
      const clarityScript = document.createElement("script");
      clarityScript.async = true;
      clarityScript.src = `https://www.clarity.ms/tag/${encodeURIComponent(projectId)}`;
      document.head.appendChild(clarityScript);
    }

    function trackEvent(eventName, eventParams = {}) {
      if (typeof window.gtag === "function") {
        window.gtag("event", eventName, eventParams);
      }

      if (typeof window.clarity === "function") {
        window.clarity("event", eventName);
      }
    }

    loadGoogleAnalytics(GA_ID);
    loadMicrosoftClarity(CLARITY_ID);

    const menuToggle = document.querySelector(".menu-toggle");
    const nav = document.querySelector(".nav");

    menuToggle.addEventListener("click", () => {
      const isOpen = document.body.classList.toggle("menu-open");
      menuToggle.setAttribute("aria-expanded", String(isOpen));
      menuToggle.textContent = isOpen ? "Fechar" : "Menu";
    });

    nav.addEventListener("click", (event) => {
      if (event.target.matches("a")) {
        document.body.classList.remove("menu-open");
        menuToggle.setAttribute("aria-expanded", "false");
        menuToggle.textContent = "Menu";
      }
    });

    const revealElements = document.querySelectorAll(".reveal, .reveal-left, .reveal-right");

    revealElements.forEach((element, index) => {
      if (!element.classList.contains("reveal-delay") && !element.classList.contains("reveal-delay-2")) {
        element.style.transitionDelay = `${Math.min(index % 4, 3) * 0.08}s`;
      }
    });

    if ("IntersectionObserver" in window) {
      const revealObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            window.setTimeout(() => entry.target.classList.add("active"), 80);
            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.12,
        rootMargin: "0px 0px -90px 0px"
      });

      revealElements.forEach((element) => revealObserver.observe(element));
    } else {
      revealElements.forEach((element) => element.classList.add("active"));
    }

    const trackedSections = [
      { selector: "#lanches", eventName: "view_cardapio" },
      { selector: "#lanches .section-heading", eventName: "view_destaques" }
    ];

    if ("IntersectionObserver" in window) {
      const sectionObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            trackEvent(entry.target.dataset.trackView);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.35 });

      trackedSections.forEach(({ selector, eventName }) => {
        const element = document.querySelector(selector);
        if (element) {
          element.dataset.trackView = eventName;
          sectionObserver.observe(element);
        }
      });
    }

    document.addEventListener("click", (event) => {
      const popupClose = event.target.closest("[data-close-popup-promocao], .close-popup-promocao, .popup-promocao-close");
      if (popupClose) {
        trackEvent("close_popup_promocao");
      }

      const link = event.target.closest("a");
      if (!link) return;

      const href = link.href || "";
      const label = link.textContent.trim() || link.getAttribute("aria-label") || "";
      const normalizedHref = href.toLowerCase();

      if (normalizedHref.includes("wa.me") || normalizedHref.includes("whatsapp")) {
        trackEvent("click_whatsapp", { link_text: label });
      }

      if (normalizedHref.includes("ifood.com.br")) {
        trackEvent("click_ifood", { link_text: label });
      }

      if (normalizedHref.includes("keeta")) {
        trackEvent("click_keeta", { link_text: label });
      }
    });

    const clubForm = document.querySelector("#clubForm");
    const clubMessage = document.querySelector("#clubMessage");

    if (clubForm && clubMessage) {
      clubForm.addEventListener("submit", async (event) => {
        event.preventDefault();

        const submitButton = clubForm.querySelector(".club-submit");
        const formData = new FormData(clubForm);
        const payload = {
          nome: formData.get("nome"),
          whatsapp: formData.get("whatsapp"),
          bairro: formData.get("bairro"),
          produto_favorito: formData.get("produto_favorito"),
          origem: "Site Ship's Burguer",
          enviado_em: new Date().toISOString()
        };

        clubMessage.textContent = "";
        clubMessage.classList.remove("error");
        submitButton.disabled = true;
        submitButton.textContent = "Enviando...";

        try {
          if (!N8N_WEBHOOK_URL) {
            throw new Error("Webhook do n8n nao configurado.");
          }

          const response = await fetch(N8N_WEBHOOK_URL, {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          if (!response.ok) {
            throw new Error("Falha no envio.");
          }

          clubForm.reset();
          trackEvent("submit_clube_ships", {
            bairro: payload.bairro,
            produto_favorito: payload.produto_favorito
          });
          clubMessage.textContent = "Cadastro enviado! Em breve vocę pode receber novidades da Ship's.";
        } catch (error) {
          clubMessage.textContent = "Năo conseguimos enviar agora. Tente novamente em instantes.";
          clubMessage.classList.add("error");
        } finally {
          submitButton.disabled = false;
          submitButton.textContent = "Entrar para o Clube";
        }
      });
    }
  </script>
  <a href="https://wa.me/5511976374369?text=Ol%C3%A1,%20vim%20pelo%20site%20da%20Ship%27s%20Burguer%20e%20quero%20fazer%20um%20pedido!" target="_blank" rel="noopener" class="whatsapp-float" aria-label="Chamar a Ship's Burguer no WhatsApp"><img src="images/logo-whats-clean.svg" alt="WhatsApp"></a>
</body>
